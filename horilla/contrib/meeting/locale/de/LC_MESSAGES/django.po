msgid ""
"Enable meeting integration to allow users to generate and share meeting "
"links using Zoom, Google Meet, Microsoft Teams, and more."
msgstr ""
"Aktivieren Sie die Besprechungsintegration, damit Benutzer Besprechungslinks "
"mit Zoom, Google Meet, Microsoft Teams und mehr generieren und teilen koennen."

msgid "Enable Meeting Integration"
msgstr "Besprechungsintegration aktivieren"

msgid "Disable Meeting Integration?"
msgstr "Besprechungsintegration deaktivieren?"

msgid "Users will no longer be able to create meeting links."
msgstr "Benutzer werden keine Besprechungslinks mehr erstellen koennen."

msgid "Enable Meeting Integration?"
msgstr "Besprechungsintegration aktivieren?"

msgid "Enabled — users can now create meeting links"
msgstr "Aktiviert — Benutzer koennen jetzt Besprechungslinks erstellen"

msgid "Disabled — users cannot create meeting links"
msgstr "Deaktiviert — Benutzer koennen keine Besprechungslinks erstellen"

msgid "Access Control"
msgstr "Zugangskontrolle"

msgid "Choose who can generate meeting links."
msgstr "Waehlen Sie, wer Besprechungslinks generieren kann."

msgid "Set access to All Users?"
msgstr "Zugriff fuer alle Benutzer festlegen?"

msgid "Every user in the company will be able to create meeting links."
msgstr "Jeder Benutzer im Unternehmen wird Besprechungslinks erstellen koennen."

msgid "Every user in the company can use meeting links."
msgstr "Jeder Benutzer im Unternehmen kann Besprechungslinks verwenden."

