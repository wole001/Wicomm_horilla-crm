msgid "Meeting Links"
msgstr "روابط الاجتماعات"

msgid ""
"Enable meeting integration to allow users to generate and share meeting "
"links using Zoom, Google Meet, Microsoft Teams, and more."
msgstr ""
"فعّل تكامل الاجتماعات للسماح للمستخدمين بإنشاء روابط الاجتماعات ومشاركتها "
"باستخدام Zoom وGoogle Meet وMicrosoft Teams والمزيد."

msgid "Enable Meeting Integration"
msgstr "تفعيل تكامل الاجتماعات"

msgid "Disable Meeting Integration?"
msgstr "هل تريد تعطيل تكامل الاجتماعات؟"

msgid "Users will no longer be able to create meeting links."
msgstr "لن يتمكن المستخدمون من إنشاء روابط الاجتماعات بعد الآن."

msgid "Enable Meeting Integration?"
msgstr "هل تريد تفعيل تكامل الاجتماعات؟"

msgid "Enabled — users can now create meeting links"
msgstr "مفعّل — يمكن للمستخدمين الآن إنشاء روابط الاجتماعات"

msgid "Disabled — users cannot create meeting links"
msgstr "معطّل — لا يمكن للمستخدمين إنشاء روابط الاجتماعات"

msgid "Access Control"
msgstr "التحكم في الوصول"

msgid "Choose who can generate meeting links."
msgstr "اختر من يمكنه إنشاء روابط الاجتماعات."

msgid "Set access to All Users?"
msgstr "هل تريد تعيين الوصول لجميع المستخدمين؟"

msgid "Every user in the company will be able to create meeting links."
msgstr "سيتمكن كل مستخدم في الشركة من إنشاء روابط الاجتماعات."

msgid "Every user in the company can use meeting links."
msgstr "يمكن لكل مستخدم في الشركة استخدام روابط الاجتماعات."

msgid "Active"
msgstr "نشط"

msgid "Click to activate"
msgstr "انقر للتفعيل"

msgid "Select Specific Roles?"
msgstr "هل تريد اختيار أدوار محددة؟"

msgid "Only users with selected roles will be able to create meeting links."
msgstr "فقط المستخدمون الذين لديهم الأدوار المحددة سيتمكنون من إنشاء روابط الاجتماعات."

msgid "Only users with selected roles can use meeting links."
msgstr "فقط المستخدمون الذين لديهم الأدوار المحددة يمكنهم استخدام روابط الاجتماعات."

msgid "· Click to add or remove roles."
msgstr "· انقر لإضافة الأدوار أو إزالتها."

msgid "role(s)"
msgstr "دور/أدوار"

msgid "Click to select"
msgstr "انقر للاختيار"

msgid "Select Specific Users?"
msgstr "هل تريد اختيار مستخدمين محددين؟"

msgid "Only selected users will be able to create meeting links."
msgstr "فقط المستخدمون المحددون سيتمكنون من إنشاء روابط الاجتماعات."

msgid "Only selected individual users can use meeting links."
msgstr "فقط المستخدمون الأفراد المحددون يمكنهم استخدام روابط الاجتماعات."

msgid "· Click to add or remove users."
msgstr "· انقر لإضافة المستخدمين أو إزالتهم."

msgid "user(s)"
msgstr "مستخدم/مستخدمون"

msgid "Name"
msgstr "الاسم"

