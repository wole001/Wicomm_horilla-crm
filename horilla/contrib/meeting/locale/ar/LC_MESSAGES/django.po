msgid "How to set up Zoom OAuth"
msgstr "كيفية إعداد Zoom OAuth"

msgid "Go to Zoom Marketplace"
msgstr "الانتقال إلى Zoom Marketplace"

msgid "Visit"
msgstr "زيارة"

msgid "and sign in."
msgstr "وتسجيل الدخول."

msgid "Create an OAuth app"
msgstr "إنشاء تطبيق OAuth"

msgid "Click \"Build App\" → choose \"OAuth\" → select \"User-managed\"."
msgstr "انقر على «Build App» ← اختر «OAuth» ← اختر «User-managed»."

msgid "Add redirect URI"
msgstr "إضافة عنوان URI لإعادة التوجيه"

