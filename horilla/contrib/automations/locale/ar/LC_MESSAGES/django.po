msgid "Outgoing Mail Server"
msgstr "خادم البريد الصادر"

msgid ""
"Select the mail server to use for sending emails. If not selected, the "
"primary mail server will be used."
msgstr ""
"حدد خادم البريد المراد استخدامه لإرسال الرسائل. إذا لم يتم التحديد، سيتم "
"استخدام الخادم الأساسي."

msgid "Choose Delivery Channel"
msgstr "اختر قناة التسليم"

msgid "Target Date Field"
msgstr "حقل التاريخ المستهدف"

msgid ""
"The date field on the record to schedule around (e.g., 'close_date', "
"'due_date'). Required for scheduled automations."
msgstr ""
"حقل التاريخ في السجل المراد الجدولة حوله (مثل: 'close_date'، 'due_date'). "
"مطلوب للأتمتة المجدولة."

msgid "Adjust By"
msgstr "ضبط بمقدار"

msgid ""
"How many days/weeks/months away from the Target Date.\n"
"Use 0 to send on the same day."
msgstr ""
"عدد الأيام/الأسابيع/الأشهر بعيداً عن التاريخ المستهدف.\n"
"استخدم 0 للإرسال في نفس اليوم."

msgid "Before"
msgstr "قبل"

msgid "After"
msgstr "بعد"

msgid "Timing"
msgstr "التوقيت"

msgid ""
"Before = send earlier than the Target Date.\n"
"After = send later than the Target Date."
msgstr ""
"قبل = الإرسال قبل التاريخ المستهدف.\n"
"بعد = الإرسال بعد التاريخ المستهدف."

msgid "Days"
msgstr "أيام"

msgid "Weeks"
msgstr "أسابيع"

msgid "Months"
msgstr "أشهر"

msgid "Offset Unit"
msgstr "وحدة الإزاحة"

msgid "Choose Days, Weeks, or Months."
msgstr "اختر أياماً أو أسابيع أو أشهراً."

msgid "Run Time"
msgstr "وقت التشغيل"

msgid "Optional. Leave empty to run whenever the scheduler runs."
msgstr "اختياري. اتركه فارغاً للتشغيل عند تشغيل المجدول."

msgid "Mail and Notification"
msgstr "البريد والإشعار"

msgid "Mail and Notifications"
msgstr "البريد والإشعارات"

msgid "This field is required when Trigger is 'Scheduled'."
msgstr "هذا الحقل مطلوب عندما يكون المشغّل 'مجدولاً'."

msgid ""
"Notification template is required when delivery channel is 'Send as "
"Notification'."
msgstr "قالب الإشعار مطلوب عندما تكون قناة التسليم 'إرسال كإشعار'."

msgid "Mail template is required when delivery channel is 'Send as Mail'."
msgstr "قالب البريد مطلوب عندما تكون قناة التسليم 'إرسال كبريد إلكتروني'."

msgid ""
"Outgoing mail server is required when delivery channel is 'Send as Mail'."
msgstr "خادم البريد الصادر مطلوب عندما تكون قناة التسليم 'إرسال كبريد إلكتروني'."

msgid ""
"Mail template is required when delivery channel is 'Send as Mail and "
"Notification'."
msgstr ""
"قالب البريد مطلوب عندما تكون قناة التسليم 'إرسال كبريد إلكتروني وإشعار'."

msgid ""
"Notification template is required when delivery channel is 'Send as Mail and "
"Notification'."
msgstr "قالب الإشعار مطلوب عندما تكون قناة التسليم 'إرسال كبريد إلكتروني وإشعار'."

msgid ""
"Outgoing mail server is required when delivery channel is 'Send as Mail and "
"Notification'."
msgstr ""
"خادم البريد الصادر مطلوب عندما تكون قناة التسليم 'إرسال كبريد إلكتروني "
"وإشعار'."

