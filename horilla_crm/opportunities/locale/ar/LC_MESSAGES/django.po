"Cannot delete {user.get_full_name() or user.username} from the opportunity "
"team. "
msgstr "لا يمكن حذف {user.get_full_name() or user.username} من فريق الفرصة."

msgid "An error occurred while deleting the team member."
msgstr "حدث خطأ أثناء حذف عضو الفريق."

msgid "Add Default Team"
msgstr "إضافة الفريق الافتراضي"

msgid "Opportunity ID is required"
msgstr "معرف الفرصة مطلوب"

msgid "The selected team has no default members configured."
msgstr "الفريق المختار لا يحتوي على أعضاء افتراضيين مكونين."

#, python-brace-format
msgid ""
"Successfully added {added_count} team member(s) from "
"{selected_team.team_name}."
msgstr "تمت إضافة {added_count} عضو فريق من {selected_team.team_name} بنجاح."

#, python-brace-format
msgid "{skipped_count} member(s) were already part of the opportunity team."
msgstr "{skipped_count} عضو(أعضاء) كانوا بالفعل جزءًا من فريق الفرصة."

msgid "Error adding default team members: {str(e)}"
msgstr "خطأ أثناء إضافة أعضاء الفريق الافتراضي: {str(e)}"

msgid "Add Opportunity Members"
msgstr "إضافة أعضاء الفرصة"

msgid "No active company found. Cannot save settings."
msgstr "لم يتم العثور على شركة نشطة. لا يمكن حفظ الإعدادات."

#| msgid ""
#| "Team Selling has been enabled successfully! Users can now create opportunity"
#| " teams and add team members."
msgid ""
"Team Selling has been enabled successfully. Users can now create opportunity"
" teams and add team members."
msgstr ""
"تم تفعيل البيع الجماعي بنجاح. يمكن للمستخدمين الآن إنشاء فرق الفرص وإضافة "
"أعضاء الفريق."

msgid ""
"Team Selling has been disabled and all existing opportunity teams and their "
"members have been deleted."
msgstr "تم تعطيل بيع الفريق وتم حذف جميع فرق الفرص وأعضائها الحالية."

#~ msgid " Changes"
#~ msgstr " التغييرات"
